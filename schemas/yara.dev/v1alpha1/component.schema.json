{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/component.schema.json",
  "title": "YARA Component v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "Component" },
    "metadata": { "$ref": "#/$defs/metadata" },
    "spec": {
      "type": "object", "additionalProperties": false,
      "required": ["provides", "apiContracts", "runtimeOverheadGiB", "policy"],
      "properties": {
        "provides": { "$ref": "#/$defs/nonEmptyStrings" },
        "apiContracts": { "$ref": "#/$defs/nonEmptyStrings" },
        "runtimeOverheadGiB": { "type": "number", "minimum": 0 },
        "policy": {
          "type": "object", "additionalProperties": false,
          "required": ["openSource", "externalEgress", "telemetry"],
          "properties": {
            "openSource": { "type": "boolean" },
            "externalEgress": { "type": "boolean" },
            "telemetry": { "type": "boolean" }
          }
        }
      }
    }
  },
  "$defs": {
    "metadata": { "type": "object", "additionalProperties": false, "required": ["id", "version"], "properties": { "id": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 } } },
    "nonEmptyStrings": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
  }
}
