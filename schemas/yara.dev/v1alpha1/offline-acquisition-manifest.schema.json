{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/offline-acquisition-manifest.schema.json",
  "title": "YARA OfflineAcquisitionManifest v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "OfflineAcquisitionManifest" },
    "metadata": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "manifestId"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "manifestId": { "$ref": "#/$defs/digest" }
      }
    },
    "spec": {
      "type": "object", "additionalProperties": false,
      "required": ["planId", "catalogDigest", "generatedBy", "artifacts", "policy"],
      "properties": {
        "planId": { "$ref": "#/$defs/digest" },
        "catalogDigest": { "$ref": "#/$defs/digest" },
        "generatedBy": { "$ref": "#/$defs/renderer" },
        "artifacts": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/artifact" } },
        "policy": {
          "type": "object", "additionalProperties": false,
          "required": ["networkRequiredDuringAcquisition", "networkAllowedDuringExecution", "requireDigestVerification", "requireCompleteSet"],
          "properties": {
            "networkRequiredDuringAcquisition": { "const": true },
            "networkAllowedDuringExecution": { "const": false },
            "requireDigestVerification": { "const": true },
            "requireCompleteSet": { "const": true }
          }
        }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "renderer": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "version", "target"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 }
      }
    },
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "ref", "method", "licenseId", "licenseSource"],
      "oneOf": [
        {
          "properties": { "type": { "const": "oci-image" }, "method": { "const": "mirror-oci-index" } },
          "required": ["digest", "platforms"],
          "not": { "anyOf": [{ "required": ["revision"] }, { "required": ["files"] }] }
        },
        {
          "properties": { "type": { "const": "huggingface-snapshot" }, "method": { "const": "mirror-huggingface-snapshot" } },
          "required": ["revision", "files"],
          "not": { "anyOf": [{ "required": ["digest"] }, { "required": ["platforms"] }] }
        }
      ],
      "properties": {
        "type": { "enum": ["oci-image", "huggingface-snapshot"] },
        "ref": { "type": "string", "minLength": 1 },
        "method": { "enum": ["mirror-oci-index", "mirror-huggingface-snapshot"] },
        "digest": { "$ref": "#/$defs/digest" },
        "revision": { "type": "string", "minLength": 1 },
        "platforms": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "files": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/artifactFile" } },
        "licenseId": { "type": "string", "minLength": 1 },
        "licenseSource": { "type": "string", "minLength": 1 }
      }
    },
    "artifactFile": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "digest", "sizeBytes"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest" },
        "sizeBytes": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
