{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/topology-template.schema.json",
  "title": "YARA TopologyTemplate v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "TopologyTemplate" },
    "metadata": { "$ref": "#/$defs/metadata" },
    "spec": {
      "type": "object", "additionalProperties": false,
      "required": ["satisfiesUseCases", "roles", "connections"],
      "properties": {
        "satisfiesUseCases": { "$ref": "#/$defs/nonEmptyStrings" },
        "roles": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/role" } },
        "connections": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/connection" } }
      }
    }
  },
  "$defs": {
    "metadata": { "type": "object", "additionalProperties": false, "required": ["id", "version"], "properties": { "id": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 } } },
    "nonEmptyStrings": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "role": { "type": "object", "additionalProperties": false, "required": ["id", "role", "requiresAccelerator"], "properties": { "id": { "type": "string", "minLength": 1 }, "role": { "type": "string", "minLength": 1 }, "requiresAccelerator": { "type": "boolean" } } },
    "connection": { "type": "object", "additionalProperties": false, "required": ["from", "to", "contract"], "properties": { "from": { "type": "string", "minLength": 1 }, "to": { "type": "string", "minLength": 1 }, "contract": { "type": "string", "minLength": 1 } } }
  }
}
