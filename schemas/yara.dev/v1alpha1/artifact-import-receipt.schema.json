{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/artifact-import-receipt.schema.json",
  "title": "YARA ArtifactImportReceipt v1alpha1",
  "description": "Content-addressed model artifact import receipt bound to an exact plan, bundle and target.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "ArtifactImportReceipt" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "importReceiptId"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "importReceiptId": { "$ref": "#/$defs/digest" }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recordedAt", "planId", "bundleId", "target", "importer", "verification", "modelArtifacts", "limitations"],
      "properties": {
        "recordedAt": { "type": "string", "format": "date-time" },
        "planId": { "$ref": "#/$defs/digest" },
        "bundleId": { "$ref": "#/$defs/digest" },
        "target": { "$ref": "#/$defs/target" },
        "importer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 }
          }
        },
        "verification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["digestVerified", "sizeVerified", "completeSet"],
          "properties": {
            "digestVerified": { "const": true },
            "sizeVerified": { "const": true },
            "completeSet": { "const": true }
          }
        },
        "modelArtifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/modelArtifact" }
        },
        "limitations": { "$ref": "#/$defs/limitations" }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "name": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!\\.\\.?$)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "referenceDigest", "serverVersion"],
      "properties": {
        "type": { "const": "kubernetes" },
        "referenceDigest": { "$ref": "#/$defs/digest" },
        "serverVersion": { "type": "string", "minLength": 1 }
      }
    },
    "fileBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "digest", "sizeBytes", "internalPath"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "digest": { "$ref": "#/$defs/digest" },
        "sizeBytes": { "type": "integer", "minimum": 1 },
        "internalPath": { "$ref": "#/$defs/relativePath" }
      }
    },
    "modelArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "revision", "files"],
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "revision": { "type": "string", "minLength": 1 },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/fileBinding" }
        }
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
