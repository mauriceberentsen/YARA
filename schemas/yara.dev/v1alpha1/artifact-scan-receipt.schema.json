{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/artifact-scan-receipt.schema.json",
  "title": "YARA ArtifactScanReceipt v1alpha1",
  "description": "Immutable non-secret scanner verdict evidence bound to exact transferred artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "ArtifactScanReceipt" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scanReceiptId"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "scanReceiptId": { "$ref": "#/$defs/digest" }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recordedAt", "planId", "bundleId", "catalogDigest", "target", "scanner", "verdict", "reasonReference", "priorReceiptIds", "modelArtifacts", "limitations"],
      "properties": {
        "recordedAt": { "type": "string", "format": "date-time" },
        "planId": { "$ref": "#/$defs/digest" },
        "bundleId": { "$ref": "#/$defs/digest" },
        "catalogDigest": { "$ref": "#/$defs/digest" },
        "target": { "$ref": "#/$defs/target" },
        "scanner": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "profile", "policyDigest"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "profile": { "type": "string", "minLength": 1 },
            "policyDigest": { "$ref": "#/$defs/digest" }
          }
        },
        "verdict": { "enum": ["passed", "failed", "blocked"] },
        "reasonReference": { "type": "string", "minLength": 1 },
        "priorReceiptIds": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/digest" },
          "uniqueItems": true
        },
        "modelArtifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/artifact" }
        },
        "limitations": { "$ref": "#/$defs/limitations" }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "name": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "referenceDigest", "serverVersion"],
      "properties": {
        "type": { "const": "kubernetes" },
        "referenceDigest": { "$ref": "#/$defs/digest" },
        "serverVersion": { "type": "string", "minLength": 1 }
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "digest", "sizeBytes"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest" },
        "sizeBytes": { "type": "integer", "minimum": 1 }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "revision", "files"],
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "revision": { "type": "string", "minLength": 1 },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/file" }
        }
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
