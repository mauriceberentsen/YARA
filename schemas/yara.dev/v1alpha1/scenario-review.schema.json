{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/scenario-review.schema.json",
  "title": "YARA ScenarioReview v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "ScenarioReview" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "reviewId"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" },
        "reviewId": { "$ref": "#/$defs/digest" }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject", "reviewer", "reviewedAt", "verdict"],
      "properties": {
        "subject": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scenarioId"],
          "properties": {
            "scenarioId": { "$ref": "#/$defs/digest" },
            "planId": { "$ref": "#/$defs/digest" }
          }
        },
        "reviewer": { "$ref": "#/$defs/reviewer" },
        "reviewedAt": { "type": "string", "minLength": 1 },
        "verdict": { "enum": ["approved", "changes-required", "abstained"] }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "role", "assurance"],
      "properties": {
        "identity": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "assurance": { "type": "string", "minLength": 1 }
      }
    }
  }
}
