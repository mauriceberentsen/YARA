{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/golden-scenario.schema.json",
  "title": "YARA GoldenScenario v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "GoldenScenario" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "scenarioId"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" },
        "scenarioId": { "$ref": "#/$defs/digest" }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputs", "expected", "reviewRequirements"],
      "properties": {
        "inputs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["request", "inventory", "catalog"],
          "properties": {
            "request": { "$ref": "#/$defs/input" },
            "inventory": { "$ref": "#/$defs/input" },
            "catalog": { "$ref": "#/$defs/input" }
          }
        },
        "expected": { "$ref": "#/$defs/expected" },
        "reviewRequirements": {
          "type": "object",
          "additionalProperties": false,
          "required": ["minimumIndependentReviewers", "requiredRoles"],
          "properties": {
            "minimumIndependentReviewers": { "type": "integer", "minimum": 1 },
            "requiredRoles": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "diagnosticCode": { "type": "string", "pattern": "^YARA-[A-Z]+-[0-9]{3}$" },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "digest"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decisionId", "selected"],
      "properties": {
        "decisionId": { "type": "string", "minLength": 1 },
        "selected": { "type": "string", "minLength": 1 }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome", "requiredDecisionIds", "requiredSelections", "forbiddenSelections", "requiredDiagnosticCodes"],
      "properties": {
        "outcome": { "enum": ["planned", "infeasible"] },
        "planId": { "$ref": "#/$defs/digest" },
        "requiredDecisionIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "requiredSelections": {
          "type": "array",
          "items": { "$ref": "#/$defs/selection" }
        },
        "forbiddenSelections": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "requiredDiagnosticCodes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/diagnosticCode" }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "outcome": { "const": "planned" } } },
          "then": {
            "required": ["planId"],
            "properties": {
              "requiredDecisionIds": { "minItems": 1 },
              "requiredSelections": { "minItems": 1 }
            }
          },
          "else": {
            "not": { "required": ["planId"] },
            "properties": {
              "requiredDecisionIds": { "maxItems": 0 },
              "requiredSelections": { "maxItems": 0 },
              "requiredDiagnosticCodes": { "minItems": 1 }
            }
          }
        }
      ]
    }
  }
}
