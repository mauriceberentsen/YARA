{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/catalog-coverage-report.schema.json",
  "title": "YARA CatalogCoverageReport v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "CatalogCoverageReport" },
    "metadata": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "reportId"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$" },
        "reportId": { "$ref": "#/$defs/digest" }
      }
    },
    "spec": {
      "type": "object", "additionalProperties": false,
      "required": ["catalogDigest", "complete", "summary", "capabilities", "components", "models", "hardware", "topologies", "assertions", "limitations"],
      "properties": {
        "catalogDigest": { "$ref": "#/$defs/digest" },
        "complete": { "type": "boolean" },
        "summary": { "$ref": "#/$defs/summary" },
        "capabilities": { "type": "array", "items": { "$ref": "#/$defs/manifestCoverage" } },
        "components": { "type": "array", "items": { "$ref": "#/$defs/manifestCoverage" } },
        "models": { "type": "array", "items": { "$ref": "#/$defs/manifestCoverage" } },
        "hardware": { "type": "array", "items": { "$ref": "#/$defs/manifestCoverage" } },
        "topologies": { "type": "array", "items": { "$ref": "#/$defs/manifestCoverage" } },
        "assertions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/assertionCoverage" } },
        "limitations": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "summary": {
      "type": "object", "additionalProperties": false,
      "required": ["manifestCount", "capabilityCount", "componentCount", "modelCount", "hardwareProfileCount", "assertionCount", "topologyCount", "acceptedEvidenceCount", "verifiedAuditChainCount", "promotionEligibleAssertions", "lifecyclePublicationReadyAssertions", "lifecyclePublicationBlockedAssertions"],
      "properties": {
        "manifestCount": { "type": "integer", "minimum": 0 },
        "capabilityCount": { "type": "integer", "minimum": 0 },
        "componentCount": { "type": "integer", "minimum": 0 },
        "modelCount": { "type": "integer", "minimum": 0 },
        "hardwareProfileCount": { "type": "integer", "minimum": 0 },
        "assertionCount": { "type": "integer", "minimum": 0 },
        "topologyCount": { "type": "integer", "minimum": 0 },
        "acceptedEvidenceCount": { "type": "integer", "minimum": 0 },
        "verifiedAuditChainCount": { "type": "integer", "minimum": 0 },
        "promotionEligibleAssertions": { "type": "integer", "minimum": 0 },
        "lifecyclePublicationReadyAssertions": { "type": "integer", "minimum": 0 },
        "lifecyclePublicationBlockedAssertions": { "type": "integer", "minimum": 0 }
      }
    },
    "manifestCoverage": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "version", "status", "coverage", "relatedAssertions", "passedModes", "blockers"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "status": { "enum": ["known", "experimental", "supported", "deprecated", "quarantined"] },
        "coverage": { "enum": ["none", "partial", "complete"] },
        "relatedAssertions": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "passedModes": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "blockers": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "assertionCoverage": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "status", "runtimeRef", "modelRef", "hardwareProfileRef", "promotionEligible", "lifecyclePublicationReady", "gates", "blockers"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["known", "experimental", "supported", "deprecated", "quarantined"] },
        "runtimeRef": { "type": "string", "minLength": 1 },
        "modelRef": { "type": "string", "minLength": 1 },
        "hardwareProfileRef": { "type": "string", "minLength": 1 },
        "promotionEligible": { "type": "boolean" },
        "lifecyclePublicationReady": { "type": "boolean" },
        "lifecyclePublicationBlocker": { "type": "string", "pattern": "^[a-z0-9-]+\\|remediation:[a-z0-9-]+$" },
        "gates": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/gate" } },
        "blockers": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "gate": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "status", "observedEvidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["passed", "failed", "blocked", "missing", "not-implemented"] },
        "selectedResultId": { "$ref": "#/$defs/digest" },
        "selectedAuditHead": { "$ref": "#/$defs/digest" },
        "observedEvidence": { "type": "array", "items": { "$ref": "#/$defs/evidenceBinding" } },
        "blocker": { "type": "string", "minLength": 1 }
      }
    },
    "evidenceBinding": {
      "type": "object", "additionalProperties": false,
      "required": ["resultId", "outcome", "auditHead"],
      "properties": {
        "resultId": { "$ref": "#/$defs/digest" },
        "outcome": { "enum": ["passed", "failed", "blocked"] },
        "auditHead": { "$ref": "#/$defs/digest" }
      }
    }
  }
}
