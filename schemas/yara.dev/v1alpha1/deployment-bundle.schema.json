{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/deployment-bundle.schema.json",
  "title": "YARA DeploymentBundle v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "DeploymentBundle" },
    "metadata": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "bundleId"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "bundleId": { "$ref": "#/$defs/digest" }
      }
    },
    "spec": {
      "type": "object", "additionalProperties": false,
      "required": ["planId", "catalogDigest", "renderer", "files", "artifacts", "requiredInputs", "operations", "preflight", "postflight", "limitations"],
      "properties": {
        "planId": { "$ref": "#/$defs/digest" },
        "catalogDigest": { "$ref": "#/$defs/digest" },
        "renderer": { "$ref": "#/$defs/renderer" },
        "files": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/file" } },
        "artifacts": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/artifact" } },
        "requiredInputs": { "type": "array", "items": { "$ref": "#/$defs/requiredInput" } },
        "operations": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/operation" } },
        "preflight": { "$ref": "#/$defs/nonEmptyStrings" },
        "postflight": { "$ref": "#/$defs/nonEmptyStrings" },
        "limitations": { "$ref": "#/$defs/nonEmptyStrings" }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "nonEmptyStrings": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "renderer": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "version", "target"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 }
      }
    },
    "file": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "mediaType", "digest", "content"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "mediaType": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest" },
        "content": { "type": "string", "minLength": 1 }
      }
    },
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "ref", "licenseId", "licenseSource"],
      "oneOf": [
        {
          "properties": { "type": { "const": "oci-image" } },
          "required": ["digest", "platforms"],
          "not": { "anyOf": [{ "required": ["revision"] }, { "required": ["files"] }] }
        },
        {
          "properties": { "type": { "const": "huggingface-snapshot" } },
          "required": ["revision", "files"],
          "not": { "anyOf": [{ "required": ["digest"] }, { "required": ["platforms"] }] }
        }
      ],
      "properties": {
        "type": { "enum": ["oci-image", "huggingface-snapshot"] },
        "ref": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest" },
        "revision": { "type": "string", "minLength": 1 },
        "platforms": { "$ref": "#/$defs/nonEmptyStrings" },
        "files": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/artifactFile" } },
        "licenseId": { "type": "string", "minLength": 1 },
        "licenseSource": { "type": "string", "minLength": 1 }
      }
    },
    "artifactFile": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "digest", "sizeBytes"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest" },
        "sizeBytes": { "type": "integer", "minimum": 1 }
      }
    },
    "requiredInput": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "secret", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "secret": { "type": "boolean" },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "operation": {
      "type": "object", "additionalProperties": false,
      "required": ["stage", "action", "instanceId"],
      "properties": {
        "stage": { "type": "integer", "minimum": 0 },
        "action": { "enum": ["create", "remove", "update", "verify"] },
        "instanceId": { "type": "string", "minLength": 1 }
      }
    }
  }
}
