{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/execution-authorization.schema.json",
  "title": "YARA ExecutionAuthorization v1alpha1",
  "description": "A short-lived Ed25519-signed capability for one exact reviewed target operation set.",
  "type": "object", "additionalProperties": false, "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" }, "kind": { "const": "ExecutionAuthorization" },
    "metadata": { "type": "object", "additionalProperties": false, "required": ["name", "authorizationId"], "properties": { "name": { "$ref": "#/$defs/name" }, "authorizationId": { "$ref": "#/$defs/digest" } } },
    "spec": {
      "type": "object", "additionalProperties": false,
      "required": ["issuedAt", "expiresAt", "planId", "bundleId", "preflightResultId", "changeSetId", "approvalId", "target", "issuer", "constraints", "signature"],
      "properties": {
        "issuedAt": { "type": "string", "format": "date-time" }, "expiresAt": { "type": "string", "format": "date-time" },
        "planId": { "$ref": "#/$defs/digest" }, "bundleId": { "$ref": "#/$defs/digest" }, "preflightResultId": { "$ref": "#/$defs/digest" }, "changeSetId": { "$ref": "#/$defs/digest" }, "approvalId": { "$ref": "#/$defs/digest" },
        "target": { "$ref": "#/$defs/target" },
        "issuer": { "type": "object", "additionalProperties": false, "required": ["keyId", "algorithm", "publicKeyDigest"], "properties": { "keyId": { "type": "string", "minLength": 1 }, "algorithm": { "const": "Ed25519" }, "publicKeyDigest": { "$ref": "#/$defs/digest" } } },
        "constraints": {
          "type": "object", "additionalProperties": false, "required": ["allowedActions", "maxOperations", "allowDelete", "allowActiveVerification", "acceptedPreflightBlockers"],
          "properties": {
            "allowedActions": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["create", "no-op", "update"] } },
            "maxOperations": { "type": "integer", "minimum": 1, "maximum": 100 }, "allowDelete": { "const": false }, "allowActiveVerification": { "type": "boolean" },
            "acceptedPreflightBlockers": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^YARA-[A-Z]+-[0-9]{3}$" } }
          }
        },
        "signature": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }, "name": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" },
    "target": { "type": "object", "additionalProperties": false, "required": ["type", "referenceDigest", "serverVersion"], "properties": { "type": { "const": "kubernetes" }, "referenceDigest": { "$ref": "#/$defs/digest" }, "serverVersion": { "type": "string", "minLength": 1 } } }
  }
}
