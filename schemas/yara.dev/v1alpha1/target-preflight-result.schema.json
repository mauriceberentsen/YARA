{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/target-preflight-result.schema.json",
  "title": "YARA TargetPreflightResult v1alpha1",
  "description": "A content-addressed, bounded read-only observation of a Kubernetes deployment target. This resource is not deployment approval.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "TargetPreflightResult" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "resultId"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" },
        "resultId": { "$ref": "#/$defs/digest" }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome", "observedAt", "bundleId", "planId", "observer", "target", "checks", "limitations"],
      "properties": {
        "outcome": { "enum": ["passed", "failed", "blocked"] },
        "observedAt": { "type": "string", "format": "date-time" },
        "bundleId": { "$ref": "#/$defs/digest" },
        "planId": { "$ref": "#/$defs/digest" },
        "observer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "mode"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "mode": { "const": "read-only" }
          }
        },
        "target": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "referenceDigest", "serverVersion"],
          "properties": {
            "type": { "const": "kubernetes" },
            "referenceDigest": { "$ref": "#/$defs/digest" },
            "serverVersion": { "type": "string", "minLength": 1 }
          }
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/check" }
        },
        "limitations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "summary", "evidenceDigest", "facts"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["passed", "failed", "blocked"] },
        "diagnosticCode": { "type": "string", "pattern": "^YARA-[A-Z]+-[0-9]{3}$" },
        "summary": { "type": "string", "minLength": 1 },
        "evidenceDigest": { "$ref": "#/$defs/digest" },
        "facts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "value"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "value": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
