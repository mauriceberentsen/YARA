{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/airgap-provenance-gate-result.schema.json",
  "title": "YARA AirgapProvenanceGateResult v1alpha1",
  "description": "Deterministic evaluation result for air-gapped provenance policy gate bindings.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "AirgapProvenanceGateResult" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "gateResultId"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "gateResultId": { "$ref": "#/$defs/digest" }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recordedAt", "expiresAt", "planId", "bundleId", "catalogDigest", "target", "importReceiptId", "transferReceiptIds", "scanReceiptIds", "gates", "outcome", "reasonReference", "signer", "signature", "limitations"],
      "properties": {
        "recordedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "planId": { "$ref": "#/$defs/digest" },
        "bundleId": { "$ref": "#/$defs/digest" },
        "catalogDigest": { "$ref": "#/$defs/digest" },
        "target": { "$ref": "#/$defs/target" },
        "importReceiptId": { "$ref": "#/$defs/digest" },
        "transferReceiptIds": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/digest" },
          "uniqueItems": true
        },
        "scanReceiptIds": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/digest" },
          "uniqueItems": true
        },
        "gates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/gate" }
        },
        "outcome": { "enum": ["passed", "failed", "blocked"] },
        "reasonReference": { "type": "string", "minLength": 1 },
        "signer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["keyId", "algorithm", "publicKeyDigest"],
          "properties": {
            "keyId": { "type": "string", "minLength": 1 },
            "algorithm": { "const": "Ed25519" },
            "publicKeyDigest": { "$ref": "#/$defs/digest" }
          }
        },
        "signature": { "type": "string", "minLength": 1 },
        "limitations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "name": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "referenceDigest", "serverVersion"],
      "properties": {
        "type": { "const": "kubernetes" },
        "referenceDigest": { "$ref": "#/$defs/digest" },
        "serverVersion": { "type": "string", "minLength": 1 }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["passed", "failed", "blocked"] },
        "blocker": { "type": "string", "minLength": 1 }
      }
    }
  }
}
