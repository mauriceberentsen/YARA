{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/catalog-snapshot.schema.json",
  "title": "YARA CatalogSnapshot v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "CatalogSnapshot" },
    "metadata": { "$ref": "#/$defs/snapshotMetadata" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifests"],
      "properties": {
        "manifests": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$" }
        }
      }
    }
  },
  "$defs": {
    "snapshotMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "publishedAt"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "publishedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
