{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/catalog-snapshot.schema.json",
  "title": "YARA CatalogSnapshot v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "CatalogSnapshot" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidates"],
      "properties": {
        "candidates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/candidate" }
        }
      }
    }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "runtimeRef", "modelRef", "capabilities", "apiContracts", "memory", "policy", "preferenceScore", "evidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "runtimeRef": { "type": "string", "minLength": 1 },
        "modelRef": { "type": "string", "minLength": 1 },
        "capabilities": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "apiContracts": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "memory": {
          "type": "object",
          "additionalProperties": false,
          "required": ["weightsGiB", "runtimeOverheadGiB", "kvCachePerConcurrentRequestGiB", "headroomPercent"],
          "properties": {
            "weightsGiB": { "type": "number", "exclusiveMinimum": 0 },
            "runtimeOverheadGiB": { "type": "number", "minimum": 0 },
            "kvCachePerConcurrentRequestGiB": { "type": "number", "minimum": 0 },
            "headroomPercent": { "type": "number", "minimum": 0, "exclusiveMaximum": 100 }
          }
        },
        "policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["openSource", "externalEgress", "telemetry", "artifactVerified"],
          "properties": {
            "openSource": { "type": "boolean" },
            "externalEgress": { "type": "boolean" },
            "telemetry": { "type": "boolean" },
            "artifactVerified": { "type": "boolean" }
          }
        },
        "preferenceScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "confidence"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "confidence": { "enum": ["high", "medium", "low"] }
            }
          }
        }
      }
    }
  }
}
