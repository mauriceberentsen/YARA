{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/deployment-receipt.schema.json",
  "title": "YARA DeploymentReceipt v1alpha1",
  "description": "Content-addressed executor outcome contract bound to the signed execution authorization.",
  "type": "object", "additionalProperties": false, "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" }, "kind": { "const": "DeploymentReceipt" },
    "metadata": { "type": "object", "additionalProperties": false, "required": ["name", "receiptId"], "properties": { "name": { "$ref": "#/$defs/name" }, "receiptId": { "$ref": "#/$defs/digest" } } },
    "spec": {
      "type": "object", "additionalProperties": false,
      "required": ["outcome", "startedAt", "completedAt", "executionCorrelationId", "planId", "bundleId", "preflightResultId", "changeSetId", "approvalId", "authorizationId", "target", "executor", "operations", "postflight", "limitations"],
      "properties": {
        "outcome": { "enum": ["succeeded", "failed", "partial"] }, "startedAt": { "type": "string", "format": "date-time" }, "completedAt": { "type": "string", "format": "date-time" }, "executionCorrelationId": { "type": "string", "minLength": 1 },
        "planId": { "$ref": "#/$defs/digest" }, "bundleId": { "$ref": "#/$defs/digest" }, "preflightResultId": { "$ref": "#/$defs/digest" }, "changeSetId": { "$ref": "#/$defs/digest" }, "approvalId": { "$ref": "#/$defs/digest" }, "authorizationId": { "$ref": "#/$defs/digest" },
        "target": { "$ref": "#/$defs/target" },
        "executor": { "type": "object", "additionalProperties": false, "required": ["name", "version", "binaryDigest"], "properties": { "name": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 }, "binaryDigest": { "$ref": "#/$defs/digest" } } },
        "operations": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/operation" } },
        "postflight": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/check" } },
        "limitations": { "$ref": "#/$defs/limitations" }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }, "name": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" },
    "target": { "type": "object", "additionalProperties": false, "required": ["type", "referenceDigest", "serverVersion"], "properties": { "type": { "const": "kubernetes" }, "referenceDigest": { "$ref": "#/$defs/digest" }, "serverVersion": { "type": "string", "minLength": 1 } } },
    "resource": { "type": "object", "additionalProperties": false, "required": ["apiVersion", "kind", "name"], "properties": { "apiVersion": { "type": "string", "minLength": 1 }, "kind": { "type": "string", "minLength": 1 }, "namespace": { "type": "string", "minLength": 1 }, "name": { "type": "string", "minLength": 1 } } },
    "operation": { "type": "object", "additionalProperties": false, "required": ["resource", "action", "outcome"], "properties": { "resource": { "$ref": "#/$defs/resource" }, "action": { "enum": ["create", "update", "no-op"] }, "outcome": { "enum": ["applied", "unchanged", "failed", "skipped"] }, "beforeDigest": { "$ref": "#/$defs/digest" }, "afterDigest": { "$ref": "#/$defs/digest" }, "diagnosticCode": { "type": "string", "pattern": "^YARA-[A-Z]+-[0-9]{3}$" } } },
    "check": { "type": "object", "additionalProperties": false, "required": ["id", "status", "evidenceDigest"], "properties": { "id": { "type": "string", "minLength": 1 }, "status": { "enum": ["passed", "failed", "blocked"] }, "evidenceDigest": { "$ref": "#/$defs/digest" }, "diagnosticCode": { "type": "string", "pattern": "^YARA-[A-Z]+-[0-9]{3}$" } } },
    "limitations": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
  }
}
