{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/capability.schema.json",
  "title": "YARA Capability v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "Capability" },
    "metadata": { "$ref": "#/$defs/metadata" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description"],
      "properties": { "description": { "type": "string", "minLength": 1 } }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object", "additionalProperties": false, "required": ["id", "version"],
      "properties": { "id": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 } }
    }
  }
}
