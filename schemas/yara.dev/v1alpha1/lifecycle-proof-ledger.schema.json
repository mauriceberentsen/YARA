{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/lifecycle-proof-ledger.schema.json",
  "title": "YARA LifecycleProofLedger v1alpha1",
  "description": "Deterministic lifecycle rehearsal ledger linking apply, retire and rollback receipt identities.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "LifecycleProofLedger" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "ledgerId"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "ledgerId": { "$ref": "#/$defs/digest" }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recordedAt", "planId", "bundleId", "targetReferenceDigest", "reviewer", "decision", "reasonReference", "stages", "limitations"],
      "properties": {
        "recordedAt": { "type": "string", "format": "date-time" },
        "planId": { "$ref": "#/$defs/digest" },
        "bundleId": { "$ref": "#/$defs/digest" },
        "targetReferenceDigest": { "$ref": "#/$defs/digest" },
        "reviewer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["identity", "role", "assurance"],
          "properties": {
            "identity": { "type": "string", "minLength": 1 },
            "role": { "type": "string", "minLength": 1 },
            "assurance": { "type": "string", "minLength": 1 }
          }
        },
        "decision": { "enum": ["approved", "changes-required", "abstained"] },
        "reasonReference": { "type": "string", "minLength": 1 },
        "stages": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/stage" }
        },
        "limitations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "name": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "receiptId", "executionCorrelationId", "outcome", "completedAt"],
      "properties": {
        "stage": { "enum": ["apply", "retire", "rollback"] },
        "receiptId": { "$ref": "#/$defs/digest" },
        "executionCorrelationId": { "type": "string", "minLength": 1 },
        "outcome": { "const": "succeeded" },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
