{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/compatibility-assertion.schema.json",
  "title": "YARA CompatibilityAssertion v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "provenance", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "CompatibilityAssertion" },
    "metadata": { "$ref": "catalog-manifest-common.schema.json#/$defs/metadata" },
    "provenance": { "$ref": "catalog-manifest-common.schema.json#/$defs/provenance" },
    "spec": {
      "type": "object", "additionalProperties": false,
      "required": ["runtimeRef", "modelRef", "hardwareProfileRef", "compatibility", "artifactVerified", "evidence"],
      "properties": {
        "runtimeRef": { "type": "string", "minLength": 1 },
        "modelRef": { "type": "string", "minLength": 1 },
        "hardwareProfileRef": { "type": "string", "minLength": 1 },
        "compatibility": { "enum": ["supported", "unsupported"] },
        "artifactVerified": { "type": "boolean" },
        "evidence": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false, "required": ["id", "confidence"],
            "properties": { "id": { "type": "string", "minLength": 1 }, "confidence": { "enum": ["high", "medium", "low"] }, "source": { "type": "string", "minLength": 1 } }
          }
        },
        "conditions": {
          "type": "object", "additionalProperties": false,
          "properties": {
            "runtimeVersion": { "type": "string", "minLength": 1 },
            "modelRevision": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
            "minimumDriverVersion": { "type": "string", "minLength": 1 },
            "computePlatform": { "type": "string", "minLength": 1 },
            "maximumContextTokens": { "type": "integer", "minimum": 1 }
          }
        }
      }
    }
  },
  "$defs": {
    "metadata": { "type": "object", "additionalProperties": false, "required": ["id", "version"], "properties": { "id": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 } } }
  }
}
