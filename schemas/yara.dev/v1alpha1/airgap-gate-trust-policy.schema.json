{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/airgap-gate-trust-policy.schema.json",
  "title": "YARA AirgapGateTrustPolicy v1alpha1",
  "description": "Content-addressed trust policy for signed air-gap provenance gate verification.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "AirgapGateTrustPolicy" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "policyId"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "policyId": { "$ref": "#/$defs/digest" }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recordedAt", "targetReferenceDigest", "trustedSignerIdentities", "limitations"],
      "properties": {
        "recordedAt": { "type": "string", "format": "date-time" },
        "targetReferenceDigest": { "$ref": "#/$defs/digest" },
        "trustedSignerIdentities": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/signer" }
        },
        "limitations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "name": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" },
    "signer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keyId", "algorithm", "publicKey", "publicKeyDigest", "status"],
      "properties": {
        "keyId": { "type": "string", "minLength": 1 },
        "algorithm": { "const": "Ed25519" },
        "publicKey": { "type": "string", "minLength": 1 },
        "publicKeyDigest": { "$ref": "#/$defs/digest" },
        "validFrom": { "type": "string", "format": "date-time" },
        "validUntil": { "type": "string", "format": "date-time" },
        "status": { "enum": ["active", "revoked"] }
      }
    }
  }
}
