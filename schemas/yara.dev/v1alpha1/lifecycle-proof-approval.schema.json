{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/lifecycle-proof-approval.schema.json",
  "title": "YARA LifecycleProofApproval v1alpha1",
  "description": "Independent publication-eligibility review for one lifecycle proof ledger identity.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "LifecycleProofApproval" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "approvalId"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "approvalId": { "$ref": "#/$defs/digest" }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewedAt", "expiresAt", "catalogDigest", "assertionRef", "ledgerId", "selectedEvidence", "reviewer", "decision", "reasonReference", "maxLedgerAge", "limitations"],
      "properties": {
        "reviewedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "catalogDigest": { "$ref": "#/$defs/digest" },
        "assertionRef": { "type": "string", "minLength": 1 },
        "ledgerId": { "$ref": "#/$defs/digest" },
        "selectedEvidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/digest" }
        },
        "reviewer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["identity", "role", "assurance"],
          "properties": {
            "identity": { "type": "string", "minLength": 1 },
            "role": { "type": "string", "minLength": 1 },
            "assurance": { "type": "string", "minLength": 1 }
          }
        },
        "decision": { "enum": ["approved", "changes-required", "abstained"] },
        "reasonReference": { "type": "string", "minLength": 1 },
        "maxLedgerAge": { "type": "string", "pattern": "^[0-9]+(ns|us|µs|ms|s|m|h)([0-9]+(ns|us|µs|ms|s|m|h))*$" },
        "limitations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "name": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" }
  }
}
