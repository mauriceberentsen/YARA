{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/kubernetes-change-set.schema.json",
  "title": "YARA KubernetesChangeSet v1alpha1",
  "description": "A content-addressed read-only comparison; not approval or mutation authority.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "KubernetesChangeSet" },
    "metadata": {
      "type": "object", "additionalProperties": false, "required": ["name", "changeSetId"],
      "properties": { "name": { "$ref": "#/$defs/name" }, "changeSetId": { "$ref": "#/$defs/digest" } }
    },
    "spec": {
      "type": "object", "additionalProperties": false,
      "required": ["outcome", "observedAt", "bundleId", "planId", "preflightResultId", "observer", "target", "summary", "operations", "limitations"],
      "properties": {
        "outcome": { "enum": ["review-required", "blocked"] },
        "observedAt": { "type": "string", "format": "date-time" },
        "bundleId": { "$ref": "#/$defs/digest" }, "planId": { "$ref": "#/$defs/digest" }, "preflightResultId": { "$ref": "#/$defs/digest" },
        "observer": { "$ref": "#/$defs/observer" }, "target": { "$ref": "#/$defs/target" },
        "summary": {
          "type": "object", "additionalProperties": false,
          "required": ["creates", "updates", "noOps", "conflicts", "unresolved", "deletes"],
          "properties": {
            "creates": { "$ref": "#/$defs/count" }, "updates": { "$ref": "#/$defs/count" }, "noOps": { "$ref": "#/$defs/count" },
            "conflicts": { "$ref": "#/$defs/count" }, "unresolved": { "$ref": "#/$defs/count" }, "deletes": { "const": 0 }
          }
        },
        "operations": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/operation" } },
        "limitations": { "$ref": "#/$defs/limitations" }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "name": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" },
    "count": { "type": "integer", "minimum": 0 },
    "observer": {
      "type": "object", "additionalProperties": false, "required": ["name", "version", "mode"],
      "properties": { "name": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 }, "mode": { "const": "read-only" } }
    },
    "target": {
      "type": "object", "additionalProperties": false, "required": ["type", "referenceDigest", "serverVersion"],
      "properties": { "type": { "const": "kubernetes" }, "referenceDigest": { "$ref": "#/$defs/digest" }, "serverVersion": { "type": "string", "minLength": 1 } }
    },
    "resource": {
      "type": "object", "additionalProperties": false, "required": ["apiVersion", "kind", "name"],
      "properties": { "apiVersion": { "type": "string", "minLength": 1 }, "kind": { "type": "string", "minLength": 1 }, "namespace": { "type": "string", "minLength": 1 }, "name": { "type": "string", "minLength": 1 } }
    },
    "operation": {
      "type": "object", "additionalProperties": false,
      "required": ["resource", "action", "ownership", "desiredDigest", "riskClasses"],
      "properties": {
        "resource": { "$ref": "#/$defs/resource" }, "action": { "enum": ["create", "update", "no-op", "conflict", "unresolved"] },
        "ownership": { "enum": ["absent", "owned", "foreign", "unknown"] }, "desiredDigest": { "$ref": "#/$defs/digest" },
        "currentDigest": { "$ref": "#/$defs/digest" }, "riskClasses": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "diagnosticCode": { "type": "string", "pattern": "^YARA-[A-Z]+-[0-9]{3}$" }
      }
    },
    "limitations": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
  }
}
