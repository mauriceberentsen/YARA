{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/catalog-manifest-common.schema.json",
  "title": "YARA catalog manifest common definitions v1alpha1",
  "$defs": {
    "metadata": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "version", "status", "owners"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "status": { "enum": ["known", "experimental", "supported", "deprecated", "quarantined"] },
        "owners": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "provenance": {
      "type": "object", "additionalProperties": false,
      "required": ["sources", "verifiedAt", "reviewAfter", "confidence"],
      "properties": {
        "sources": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/source" } },
        "verifiedAt": { "type": "string", "format": "date-time" },
        "reviewAfter": { "type": "string", "format": "date-time" },
        "confidence": { "enum": ["high", "medium", "low"] }
      }
    },
    "source": {
      "type": "object", "additionalProperties": false, "required": ["type", "ref"],
      "properties": { "type": { "type": "string", "minLength": 1 }, "ref": { "type": "string", "minLength": 1 } }
    }
  }
}
