{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/catalog-manifest-common.schema.json",
  "title": "YARA catalog manifest common definitions v1alpha1",
  "$defs": {
    "metadata": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "version", "status", "owners"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "status": { "enum": ["known", "experimental", "supported", "deprecated", "quarantined"] },
        "owners": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "provenance": {
      "type": "object", "additionalProperties": false,
      "required": ["sources", "verifiedAt", "reviewAfter", "confidence"],
      "properties": {
        "sources": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/source" } },
        "verifiedAt": { "type": "string", "format": "date-time" },
        "reviewAfter": { "type": "string", "format": "date-time" },
        "confidence": { "enum": ["high", "medium", "low"] }
      }
    },
    "source": {
      "type": "object", "additionalProperties": false, "required": ["type", "ref"],
      "properties": { "type": { "type": "string", "minLength": 1 }, "ref": { "type": "string", "minLength": 1 } }
    },
    "license": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "source", "osiApproved", "redistribution"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "osiApproved": { "type": "boolean" },
        "redistribution": { "enum": ["allowed", "allowed-with-conditions", "unknown", "forbidden"] },
        "restrictions": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "ref"],
      "properties": {
        "type": { "enum": ["oci-image", "huggingface-snapshot"] },
        "ref": { "type": "string", "minLength": 1 },
        "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "revision": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "platforms": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z0-9]+/[a-z0-9_]+$" } },
        "files": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/artifactFile" } }
      }
    },
    "artifactFile": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "digest", "sizeBytes"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "sizeBytes": { "type": "integer", "minimum": 1 }
      }
    },
    "health": {
      "type": "object", "additionalProperties": false,
      "required": ["protocol"],
      "properties": {
        "protocol": { "enum": ["http", "tcp", "exec"] },
        "path": { "type": "string", "pattern": "^/" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "command": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      },
      "oneOf": [
        { "required": ["path"], "properties": { "protocol": { "const": "http" } } },
        { "required": ["port"], "properties": { "protocol": { "const": "tcp" } } },
        { "required": ["command"], "properties": { "protocol": { "const": "exec" } } }
      ]
    }
  }
}
