{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yara.dev/schemas/v1alpha1/bootstrap-receipt.schema.json",
  "title": "YARA BootstrapReceipt v1alpha1",
  "description": "Content-addressed bounded namespace/PVC bootstrap outcome contract.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "yara.dev/v1alpha1" },
    "kind": { "const": "BootstrapReceipt" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "receiptId"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "receiptId": { "$ref": "#/$defs/digest" }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome", "startedAt", "completedAt", "executionCorrelationId", "target", "namespace", "modelPvc", "storageClass", "size", "executor", "operations", "limitations"],
      "properties": {
        "outcome": { "enum": ["succeeded", "failed", "partial"] },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "executionCorrelationId": { "type": "string", "minLength": 1 },
        "target": { "$ref": "#/$defs/target" },
        "namespace": { "$ref": "#/$defs/name" },
        "modelPvc": { "$ref": "#/$defs/name" },
        "storageClass": { "$ref": "#/$defs/storageClass" },
        "size": { "$ref": "#/$defs/size" },
        "executor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "binaryDigest"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "binaryDigest": { "$ref": "#/$defs/digest" }
          }
        },
        "operations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/operation" }
        },
        "limitations": { "$ref": "#/$defs/limitations" }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "name": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" },
    "storageClass": { "type": "string", "pattern": "^[a-z0-9](?:[-a-z0-9_.]{0,251}[a-z0-9])?$" },
    "size": { "type": "string", "pattern": "^[1-9][0-9]*(?:Ei|Pi|Ti|Gi|Mi|Ki)?$" },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "referenceDigest", "serverVersion"],
      "properties": {
        "type": { "const": "kubernetes" },
        "referenceDigest": { "$ref": "#/$defs/digest" },
        "serverVersion": { "type": "string", "minLength": 1 }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["apiVersion", "kind", "name"],
      "properties": {
        "apiVersion": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resource", "action", "outcome"],
      "properties": {
        "resource": { "$ref": "#/$defs/resource" },
        "action": { "enum": ["create", "no-op"] },
        "outcome": { "enum": ["created", "unchanged", "failed", "skipped"] },
        "afterDigest": { "$ref": "#/$defs/digest" },
        "diagnosticCode": { "type": "string", "pattern": "^YARA-[A-Z]+-[0-9]{3}$" }
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
